generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Page {
  id          String   @id @default(cuid())
  url         String   @unique
  finalUrl    String
  statusCode  Int
  contentType String?
  title       String?
  html        String?  @db.Text
  contentHash String?
  fetchedAt   DateTime @default(now())
  links       Link[]

  @@index([fetchedAt])
  @@index([contentHash])
}

model Link {
  id         String   @id @default(cuid())
  fromPageId String
  fromPage   Page     @relation(fields: [fromPageId], references: [id], onDelete: Cascade)
  toUrl      String
  createdAt  DateTime @default(now())

  @@unique([fromPageId, toUrl])
  @@index([toUrl])
}

enum JobStatus {
  RUNNING
  COMPLETED
  FAILED
  STOPPED
}

model CrawlJob {
  id           String    @id @default(cuid())
  seedUrl      String
  status       JobStatus @default(RUNNING)
  maxDepth     Int
  maxPages     Int
  crawlDelay   Int
  pagesCrawled Int       @default(0)
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  error        String?

  @@index([status])
  @@index([startedAt])
}